generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  DAMAGED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditVerificationStatus {
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ASSET_ASSIGNED
  TRANSFER_APPROVED
  TRANSFER_REJECTED
  MAINTENANCE_UPDATE
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  OVERDUE_RETURN
  AUDIT_DISCREPANCY
}

enum AttachmentType {
  ASSET_IMAGE
  ASSET_DOCUMENT
  MAINTENANCE_ATTACHMENT
}

// ─────────────────────────────────────────────
// ORGANIZATION
// ─────────────────────────────────────────────

model Department {
  id          String  @id @default(uuid())
  name        String
  code        String? @unique
  description String? @db.Text

  parentId String?
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")

  headId String? @unique
  head   User?   @relation("DepartmentHead", fields: [headId], references: [id])

  isActive Boolean @default(true)

  users              User[]              @relation("DepartmentMembers")
  assets             Asset[]
  assetAllocations   AssetAllocation[]
  auditCycles        AuditCycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([isActive])
}

model AssetCategory {
  id             String  @id @default(uuid())
  name           String  @unique
  description    String? @db.Text
  metadataSchema Json?

  assets Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// USERS / AUTH
// ─────────────────────────────────────────────

model User {
  id       String     @id @default(uuid())
  name     String
  email    String     @unique
  password String
  role     UserRole   @default(EMPLOYEE)
  status   UserStatus @default(ACTIVE)

  departmentId String?
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])

  headedDepartment Department? @relation("DepartmentHead")

  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  allocations          AssetAllocation[]      @relation("AllocationEmployee")
  transfersFrom        AssetTransfer[]        @relation("TransferFrom")
  transfersTo          AssetTransfer[]        @relation("TransferTo")
  transfersApproved    AssetTransfer[]        @relation("TransferApprover")
  bookings             ResourceBooking[]
  raisedMaintenance    MaintenanceRequest[]   @relation("MaintenanceRaisedBy")
  approvedMaintenance  MaintenanceRequest[]   @relation("MaintenanceApprover")
  notifications        Notification[]
  createdAssets        Asset[]                @relation("AssetCreator")
  activityLogs         ActivityLog[]
  auditAssignments     AuditAuditor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([role])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  otp       String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// ASSETS
// ─────────────────────────────────────────────

// Auto-increment counter backing human-readable asset tags (AF-0001, AF-0002, ...).
// MySQL has no CREATE SEQUENCE, so an AUTO_INCREMENT single-column table is the
// idiomatic atomic-counter substitute — inserting a row and reading its id is
// safe under concurrent writes just like a real sequence.
model AssetTagSequence {
  id BigInt @id @default(autoincrement())

  @@map("asset_tag_seq")
}

model Asset {
  id              String          @id @default(uuid())
  assetTag        String          @unique
  name            String
  serialNumber    String?         @unique
  categoryId      String
  category        AssetCategory   @relation(fields: [categoryId], references: [id])

  status          AssetStatus     @default(AVAILABLE)
  condition       AssetCondition  @default(GOOD)

  acquisitionDate DateTime?
  acquisitionCost Decimal?        @db.Decimal(12, 2)

  location        String?         @db.VarChar(255)
  departmentId    String?
  department      Department?     @relation(fields: [departmentId], references: [id])

  isBookable Boolean @default(false)
  metadata   Json?
  qrCode     String? @db.Text

  createdById String?
  createdBy   User?   @relation("AssetCreator", fields: [createdById], references: [id])

  allocations         AssetAllocation[]
  transfers           AssetTransfer[]
  maintenanceRequests  MaintenanceRequest[]
  bookings             ResourceBooking[]
  auditItems           AuditItem[]
  attachments          Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([departmentId])
  @@index([categoryId])
  @@index([location])
}

model AssetAllocation {
  id     String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  employeeId String?
  employee   User?   @relation("AllocationEmployee", fields: [employeeId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  returnCondition    AssetCondition?
  returnNotes        String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([employeeId])
  @@index([expectedReturnDate])
}

model AssetTransfer {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  fromEmployeeId String?
  fromEmployee   User?   @relation("TransferFrom", fields: [fromEmployeeId], references: [id])

  toEmployeeId String?
  toEmployee   User?   @relation("TransferTo", fields: [toEmployeeId], references: [id])

  reason String?        @db.Text
  status TransferStatus @default(REQUESTED)

  approvedById String?
  approvedBy   User?   @relation("TransferApprover", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([status])
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model ResourceBooking {
  id     String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  bookedById String
  bookedBy   User   @relation(fields: [bookedById], references: [id])

  title     String?
  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(UPCOMING)
  remarks   String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId, startTime])
  @@index([status])
}

// ─────────────────────────────────────────────
// MAINTENANCE
// ─────────────────────────────────────────────

model MaintenanceRequest {
  id     String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  raisedById String
  raisedBy   User   @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])

  issue    String              @db.Text
  priority MaintenancePriority @default(MEDIUM)
  status   MaintenanceStatus  @default(PENDING)

  technicianName  String?
  resolutionNotes String? @db.Text

  approvedById String?
  approvedBy   User?   @relation("MaintenanceApprover", fields: [approvedById], references: [id])

  resolvedAt DateTime?
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([status])
}

// ─────────────────────────────────────────────
// AUDITS
// ─────────────────────────────────────────────

model AuditCycle {
  id           String   @id @default(uuid())
  title        String   @db.VarChar(255)
  description  String? @db.Text
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  location     String?  @db.VarChar(255)
  startDate    DateTime
  endDate      DateTime
  isClosed     Boolean  @default(false)

  auditors AuditAuditor[]
  items    AuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditAuditor {
  id      String     @id @default(uuid())
  auditId String
  audit   AuditCycle @relation(fields: [auditId], references: [id])
  userId  String
  user    User       @relation(fields: [userId], references: [id])

  @@unique([auditId, userId])
}

model AuditItem {
  id      String     @id @default(uuid())
  auditId String
  audit   AuditCycle @relation(fields: [auditId], references: [id])
  assetId String
  asset   Asset      @relation(fields: [assetId], references: [id])

  expectedLocation String?
  status           AuditVerificationStatus @default(VERIFIED)
  remarks          String?                 @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([auditId, assetId])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS / LOGS / ATTACHMENTS
// ─────────────────────────────────────────────

model Notification {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  type        NotificationType
  title       String
  message     String  @db.Text
  referenceId String?
  isRead      Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model ActivityLog {
  id     String @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action    String
  entity    String
  entityId  String
  oldData   Json?
  newData   Json?
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
}

model Attachment {
  id       String @id @default(uuid())
  fileName String @db.VarChar(255)
  fileUrl  String @db.Text
  fileSize Int?
  mimeType String?
  type     AttachmentType

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id])

  maintenanceId String?
  maintenance   MaintenanceRequest? @relation(fields: [maintenanceId], references: [id])

  uploadedAt DateTime @default(now())
}
