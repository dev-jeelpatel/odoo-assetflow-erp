# Copy to .env and fill in.
# Values below match `docker compose up -d mysql` at the repo root out of the box.
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=assetflow
DB_NAME=assetflow

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h
